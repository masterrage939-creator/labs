#include <cstdint>

uint8_t INVISIBILITY      = 1 << 0; 
uint8_t SILENCE           = 1 << 1; 
uint8_t IR_SUPPRESSION    = 1 << 2; 
uint8_t RADIO_SUPPRESSION = 1 << 3; 
uint8_t POWER_SAVE        = 1 << 4; 

uint8_t toggle_state(uint8_t state, int num) {
    if (num < 1 || num > 5) return state;
    uint8_t mask = 1 << (num - 1);
    return state ^ mask; 
}

bool is_active(uint8_t state, int num) {
    if (num < 1 || num > 5) return false;
    uint8_t mask = 1 << (num - 1);
    return (state & mask) != 0;
}

int count_active(uint8_t state) {
    int cnt = 0;
    for (int i = 0; i < 5; ++i) {
        if (state & (1 << i)) ++cnt;
    }
    return cnt;
}

bool is_detected(uint8_t state) {
    // не активна невидимость
    bool cond1 = !(state & INVISIBILITY);
    // не активно беззвучие и активно энергосбережение
    bool cond2 = !(state & SILENCE) && (state & POWER_SAVE);

    return cond1 || cond2;
}

int main() {
    uint8_t suit = 0;

    
    suit = toggle_state(suit, 1);       
    bool active1 = is_active(suit, 1);  
    suit = toggle_state(suit, 2);       
    int cnt = count_active(suit);       
    bool detected = is_detected(suit);  

    suit = toggle_state(suit, 1);       
    detected = is_detected(suit);       

    return 0;
}
